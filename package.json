{
  "name": "code-mri",
  "version": "0.0.0",
  "private": true,
  "description": "Local-first codebase intelligence with a desktop UI, CLI, CI gates, and MCP tools",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "scan": "pnpm --filter @code-mri/engine scan",
    "mcp": "pnpm --filter @code-mri/engine mcp"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "vitest": "^2.1.4",
    "tsx": "^4.19.2"
  }
}
