{
  "name": "@code-mri/engine",
  "version": "0.3.0",
  "private": false,
  "description": "Local-first code graph, impact analysis, CI gates, and MCP server for coding agents",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "bin": {
    "code-mri": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./diff": {
      "types": "./dist/diff/reportDiff.d.ts",
      "default": "./dist/diff/reportDiff.js"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "package.json"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "scan": "tsx src/cli/index.ts scan",
    "mcp": "tsx src/cli/index.ts mcp",
    "bench": "tsx bench/scan.ts",
    "build": "tsc -p tsconfig.build.json && mkdir -p dist/parsers/py-sidecar && cp -R src/parsers/py-sidecar/. dist/parsers/py-sidecar",
    "prepack": "pnpm run build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "fast-glob": "^3.3.2",
    "ignore": "^6.0.2",
    "js-yaml": "^4.2.0",
    "ts-morph": "^24.0.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.7.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
